node_modules/
.env
*.log
squads/*/output/
_opensquad/_memory/company.md
_opensquad/_memory/preferences.md
_opensquad/_browser_profile/

# Generated by 'npx opensquad init' — IDE rules and configs
# These are copied from templates/ and should not be committed
.agent/workflows/opensquad.md
.antigravity/rules.md
.claude/skills/opensquad/
.cursor/rules/opensquad.mdc
.cursor/mcp.json
.github/prompts/opensquad.prompt.md
.vscode/mcp.json
.vscode/settings.json
.cursorignore

# Squad data (user content, investigations, memories — sensitive)
squads/*/pipeline/
squads/*/_investigations/
squads/*/_memory/
squads/*/output/

# Temp files
temp/

# Claude Code local settings
.claude/settings.local.json

# OpenSquad services (contains encryption keys)
.opensquad-services/

# Playwright browsers cache
_opensquad/_browser_profile/
